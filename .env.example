PORT=3101

# Optional: move font data outside the repo so it survives Git clone / re-clone.
# Examples:
# FONT_DATA_DIR=./data
# FONT_DATA_DIR=../font-tool-data
# FONT_DATA_DIR=D:/font-tool-data
FONT_DATA_DIR=./data

# Optional: store the font library in GitHub or Gitee instead of the local data directory.
# The token needs repository content read/write permission.
# Example: https://github.com/owner/repository
FONT_REPOSITORY_URL=
FONT_REPOSITORY_TOKEN=
# Leave empty to use the repository default branch.
FONT_REPOSITORY_BRANCH=
FONT_REPOSITORY_PATH=font-data

# Copy this file to .env.local and fill in your real CDN values.
# URL template tokens:
# {filename} {basename} {ext} {hash} {sourceHash} {dateCompact} {uuid} {cdnFilename} {cdnBasename}
# Body template tokens:
# {{filename}} {{basename}} {{ext}} {{hash}} {{sourceHash}} {{size}} {{sourceBytes}}
# {{subsetCount}} {{newSubsetCount}} {{existingSubsetCount}} {{operationMode}} {{contentType}}
# {{publicUrl}} {{fileBase64}} {{dateCompact}} {{uuid}} {{cdnFilename}} {{cdnBasename}} {{cdnDirname}} {{cdnFilenameMode}}
CDN_UPLOAD_LABEL=My CDN
CDN_UPLOAD_URL_TEMPLATE=https://upload.example.com/fonts/{cdnFilename}
CDN_PUBLIC_URL_TEMPLATE=https://cdn.example.com/fonts/{cdnFilename}
CDN_UPLOAD_METHOD=PUT
CDN_AUTH_HEADER=Authorization
CDN_AUTH_TOKEN=Bearer replace-with-real-token
CDN_AUTO_UPLOAD_DEFAULT=false
CDN_UPLOAD_TIMEOUT_MS=20000
# Generated remote filename/path used by custom body templates and optional CDN URL templates.
CDN_UPLOAD_FILENAME_TEMPLATE={{filename}}
# raw: directly upload the font binary
# json: build a JSON body from CDN_UPLOAD_BODY_TEMPLATE or CDN_UPLOAD_BODY_TEMPLATE_FILE
# text: build a plain text body from CDN_UPLOAD_BODY_TEMPLATE or CDN_UPLOAD_BODY_TEMPLATE_FILE
# form: send multipart/form-data, always includes the binary file part and can add text fields from template JSON
CDN_UPLOAD_BODY_MODE=raw
# Multipart file field name when CDN_UPLOAD_BODY_MODE=form
CDN_UPLOAD_FORM_FILE_FIELD=file
# Optional multipart text field automatically filled with CDN_UPLOAD_FILENAME_TEMPLATE, e.g. filename
CDN_UPLOAD_FORM_FILENAME_FIELD=
# Optional JSON path for the public URL returned by the upload API, e.g. data.url
CDN_RESPONSE_URL_PATH=
# Optional, recommended for complex JSON bodies or multipart text fields:
CDN_UPLOAD_BODY_TEMPLATE_FILE=.cdn-upload-body.example.json
# Optional inline template. Leave empty when using CDN_UPLOAD_BODY_TEMPLATE_FILE.
CDN_UPLOAD_BODY_TEMPLATE=
# Optional extra headers as JSON, for example: {"X-Api-Key":"replace-me"}
CDN_UPLOAD_HEADERS_JSON=
